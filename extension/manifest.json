{
  "manifest_version": 3,
  "name": "Leksihjelp",
  "version": "2.4.1",
  "description": "Ordbok, uttale og ordforslag for norske elever som lærer spansk, fransk eller tysk.",
  "permissions": [
    "contextMenus",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles/content.css"],
      "js": [
        "i18n/strings.js",
        "content/vocab-store.js",
        "content/vocab-seam-core.js",
        "content/vocab-seam.js",
        "content/floating-widget.js",
        "content/word-prediction.js",
        "content/spell-check-core.js",
        "content/spell-rules/grammar-tables.js",
        "content/spell-rules/quotation-suppression.js",
        "content/spell-rules/de-capitalization.js",
        "content/spell-rules/de-perfekt-aux.js",
        "content/spell-rules/de-compound-gender.js",
        "content/spell-rules/de-gender.js",
        "content/spell-rules/de-grammar.js",
        "content/spell-rules/de-modal-verb.js",
        "content/spell-rules/en-grammar.js",
        "content/spell-rules/es-accent-guard.js",
        "content/spell-rules/es-coordination.js",
        "content/spell-rules/es-grammar.js",
        "content/spell-rules/es-fr-gender.js",
        "content/spell-rules/es-fr-modal-verb.js",
        "content/spell-rules/fr-contraction.js",
        "content/spell-rules/fr-elision.js",
        "content/spell-rules/fr-etre-avoir.js",
        "content/spell-rules/fr-grammar.js",
        "content/spell-rules/fr-preposition.js",
        "content/spell-rules/nb-codeswitch.js",
        "content/spell-rules/nb-propernoun-guard.js",
        "content/spell-rules/nb-gender.js",
        "content/spell-rules/nb-compound-gender.js",
        "content/spell-rules/nb-demonstrative-gender.js",
        "content/spell-rules/nb-modal-verb.js",
        "content/spell-rules/nb-sarskriving.js",
        "content/spell-rules/universal-agreement.js",
        "content/spell-rules/nb-dialect-mix.js",
        "content/spell-rules/nb-typo-curated.js",
        "content/spell-rules/nb-triple-letter.js",
        "content/spell-rules/nb-typo-fuzzy.js",
        "content/spell-rules/nb-homophones.js",
        "content/spell-rules/en-homophones.js",
        "content/spell-rules/universal-context-typo.js",
        "content/spell-rules/register.js",
        "content/spell-rules/collocation.js",
        "content/spell-rules/redundancy.js",
        "content/spell-rules/es-ser-estar.js",
        "content/spell-rules/es-por-para.js",
        "content/spell-rules/es-personal-a.js",
        "content/spell-rules/de-prep-case.js",
        "content/spell-rules/de-separable-verb.js",
        "content/spell-rules/de-v2.js",
        "content/spell-rules/de-verb-final.js",
        "content/spell-rules/fr-bags.js",
        "content/spell-rules/fr-pp-agreement.js",
        "content/spell-rules/nb-v2.js",
        "content/spell-rules/es-subjuntivo.js",
        "content/spell-rules/es-imperfecto-hint.js",
        "content/spell-rules/fr-subjonctif.js",
        "content/spell-rules/es-pro-drop.js",
        "content/spell-rules/es-gustar.js",
        "content/spell-rules/fr-clitic-order.js",
        "content/spell-rules/en-morphology.js",
        "content/spell-rules/en-word-family.js",
        "content/spell-rules/fr-adj-gender.js",
        "content/spell-rules/doc-drift-de-address.js",
        "content/spell-rules/doc-drift-fr-address.js",
        "content/spell-rules/doc-drift-nb-register.js",
        "content/spell-rules/doc-drift-nn-infinitive.js",
        "content/spell-check.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/*.json", "assets/*", "audio/*/*.mp3"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "lookup-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Slå opp markert tekst i Leksihjelp"
    },
    "read-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Les opp markert tekst med Leksihjelp"
    },
    "toggle-pause": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Sett Leksihjelp på pause / gjenoppta"
    }
  }
}

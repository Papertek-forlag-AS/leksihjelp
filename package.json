{
  "name": "@papertek/leksihjelp",
  "version": "2.9.33",
  "description": "Chrome extension for Norwegian students learning foreign languages",
  "files": [
    "extension/content/",
    "extension/i18n/",
    "extension/data/",
    "extension/styles/",
    "extension/popup/views/",
    "extension/popup/dict-state-builder.js",
    "extension/popup/grammar-features-section.js",
    "extension/exam-registry.js"
  ],
  "exports": {
    "./content/*": "./extension/content/*",
    "./i18n/*": "./extension/i18n/*",
    "./data/*": "./extension/data/*",
    "./styles/*": "./extension/styles/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "sync-vocab": "node scripts/sync-vocab.js",
    "sync-vocab:de": "node scripts/sync-vocab.js de",
    "sync-vocab:es": "node scripts/sync-vocab.js es",
    "sync-vocab:fr": "node scripts/sync-vocab.js fr",
    "sync-vocab:audio": "node scripts/sync-vocab.js --with-audio",
    "sync-vocab:de:audio": "node scripts/sync-vocab.js de --with-audio",
    "check-fixtures": "node scripts/check-fixtures.js",
    "check-fixtures:nb": "node scripts/check-fixtures.js nb",
    "check-fixtures:nn": "node scripts/check-fixtures.js nn",
    "build-frequencies": "node scripts/build-frequencies.js",
    "build-bigrams": "node scripts/build-bigrams.js",
    "build-nb-baseline": "node scripts/build-nb-baseline.js",
    "package": "node scripts/package-extension.js",
    "check-bundle-size": "node scripts/check-bundle-size.js",
    "check-baseline-bundle-size": "node scripts/check-baseline-bundle-size.js",
    "check-baseline-bundle-size:test": "node scripts/check-baseline-bundle-size.test.js",
    "check-exam-marker": "node scripts/check-exam-marker.js",
    "check-exam-marker:test": "node scripts/check-exam-marker.test.js",
    "check-explain-contract": "node scripts/check-explain-contract.js",
    "check-explain-contract:test": "node scripts/check-explain-contract.test.js",
    "check-pedagogy-shape": "node scripts/check-pedagogy-shape.js",
    "check-pedagogy-shape:test": "node scripts/check-pedagogy-shape.test.js",
    "check-pedagogy-id-coverage": "node scripts/check-pedagogy-id-coverage.js",
    "check-pedagogy-id-coverage:test": "node scripts/check-pedagogy-id-coverage.test.js",
    "check-network-silence": "node scripts/check-network-silence.js",
    "check-network-silence:test": "node scripts/check-network-silence.test.js",
    "check-spellcheck-features": "node scripts/check-spellcheck-features.js",
    "check-rule-css-wiring": "node scripts/check-rule-css-wiring.js",
    "check-rule-css-wiring:test": "node scripts/check-rule-css-wiring.test.js",
    "check-benchmark-coverage": "node scripts/check-benchmark-coverage.js",
    "check-benchmark-coverage:test": "node scripts/check-benchmark-coverage.test.js",
    "check-governance-data": "node scripts/check-governance-data.js",
    "check-governance-data:test": "node scripts/check-governance-data.test.js",
    "check-stateful-rule-invalidation": "node scripts/check-stateful-rule-invalidation.js",
    "check-stateful-rule-invalidation:test": "node scripts/check-stateful-rule-invalidation.test.js",
    "check-popup-deps": "node scripts/check-popup-deps.js",
    "check-popup-deps:test": "node scripts/check-popup-deps.test.js",
    "check-vocab-seam-coverage": "node scripts/check-vocab-seam-coverage.js",
    "check-vocab-seam-coverage:test": "node scripts/check-vocab-seam-coverage.test.js",
    "check-version-alignment": "node scripts/check-version-alignment.js",
    "check-version-alignment:test": "node scripts/check-version-alignment.test.js",
    "check-synced-surface-version": "node scripts/check-synced-surface-version.js",
    "check-synced-surface-version:test": "node scripts/check-synced-surface-version.test.js",
    "check-vocab-deployment": "node scripts/check-vocab-deployment.js",
    "check-fr-bundle-completeness": "node scripts/check-fr-bundle-completeness.js",
    "build-popup-views-css": "node scripts/build-popup-views-css.js",
    "test:vocab-store": "node --test extension/content/vocab-store.test.js",
    "test:vocab-seam": "node --test extension/content/vocab-seam.test.js",
    "test:popup-views": "node --test extension/popup/views/dictionary-view.test.js extension/popup/views/settings-view.test.js",
    "test:dict-state-builder": "node --test extension/popup/dict-state-builder.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Papertek-forlag-AS/leksihjelp"
  },
  "author": "Papertek",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "fake-indexeddb": "^6.2.5"
  }
}

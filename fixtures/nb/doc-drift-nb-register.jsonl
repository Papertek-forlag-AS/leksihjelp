// NB bokmal/riksmal register drift detection (DOC-03)
//
// IMPORTANT: Riksmal forms that are NOT valid NB words (efter, sne, nu, fandt,
// sagde, doren) are caught by the typo rule (priority 50) which wins dedup over
// doc-drift (priority 203). Doc-drift only surfaces for valid-NB riksmal forms
// (boken, gaten, jenten, klokken, solen) and valid-NB bokmal forms (boka, gata,
// jenta, klokka, sola). The rule still detects ALL markers for majority-vote
// purposes, but only the non-typo minority tokens produce surviving findings.

// ── Positive: bokmal-majority, riksmal minority (valid NB forms) flagged ──

// 3 bokmal (jenta, boka, gata), 1 riksmal (boken) -> flag boken
{"id":"nb-drift-pos-001","text":"Jenta gikk til skolen. Boka var god. Gata var tom. Han leste boken.","expected":[{"rule_id":"doc-drift-nb-register","start":61,"end":66,"suggestion":"boka"}],"status":"ok"}

// 3 bokmal (klokka, gata, sola), 1 riksmal (boken) -> flag boken
{"id":"nb-drift-pos-002","text":"Klokka var mye. Gata var lang. Sola skinte. Han leste boken hver dag.","expected":[{"rule_id":"doc-drift-nb-register","start":54,"end":59,"suggestion":"boka"}],"status":"ok"}

// 3 bokmal (jenta, boka, gata), 1 riksmal (solen) -> flag solen
{"id":"nb-drift-pos-003","text":"Jenta var glad. Boka var pen. Gata var fin. Solen skinte.","expected":[{"rule_id":"doc-drift-nb-register","start":44,"end":49,"suggestion":"sola"}],"status":"ok"}

// 3 bokmal (jenta, boka, gata), 1 riksmal (gaten) -> flag gaten
{"id":"nb-drift-pos-004","text":"Jenta var glad. Boka var pen. Gata var fin. Gaten var lang.","expected":[{"rule_id":"doc-drift-nb-register","start":44,"end":49,"suggestion":"gata"}],"status":"ok"}

// 3 bokmal (jenta, boka, sola), 1 riksmal (klokken) -> flag klokken
{"id":"nb-drift-pos-005","text":"Jenta var glad. Boka var pen. Sola skinte. Klokken ringte.","expected":[{"rule_id":"doc-drift-nb-register","start":43,"end":50,"suggestion":"klokka"}],"status":"ok"}

// 3 bokmal (jenta, boka, gata), 1 riksmal (jenten) -> flag jenten
{"id":"nb-drift-pos-006","text":"Jenta var glad. Boka var pen. Gata var fin. Jenten gikk.","expected":[{"rule_id":"doc-drift-nb-register","start":44,"end":50,"suggestion":"jenta"}],"status":"ok"}

// 4 bokmal (jenta, boka, gata, sola), 1 riksmal (boken) -> flag boken
{"id":"nb-drift-pos-007","text":"Jenta gikk hjem. Boka var god. Gata var tom. Sola skinte. Han leste boken.","expected":[{"rule_id":"doc-drift-nb-register","start":68,"end":73,"suggestion":"boka"}],"status":"ok"}

// 5 bokmal (jenta, boka, gata, sola, klokka), 1 riksmal (boken) -> flag boken
{"id":"nb-drift-pos-008","text":"Jenta gikk hjem. Boka var god. Gata var tom. Sola skinte. Klokka var mye. Han leste boken.","expected":[{"rule_id":"doc-drift-nb-register","start":84,"end":89,"suggestion":"boka"}],"status":"ok"}

// ── Positive: riksmal-majority, bokmal minority (valid NB forms) flagged ──


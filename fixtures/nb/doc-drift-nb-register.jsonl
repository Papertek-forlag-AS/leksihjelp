{"id":"nb-drift-pos-009","text":"Boken var god. Gaten var lang. Solen skinte. Jenta gikk hjem.","expected":[{"rule_id":"doc-drift-nb-register","start":45,"end":50,"suggestion":"jenten"}],"status":"ok"}


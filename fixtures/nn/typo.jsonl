// ── Phase 05.1 Gap D: NN↔NB dialect-mix FLAG cases ──
// Mirror of fixtures/nb/typo.jsonl. An NN document with NB-only tokens
// flags via the nb-dialect-mix rule (priority 35).
//
// Phase 05.1-05 bug-fix (smoke-test follow-up): dialect-mix now uses
// CROSS_DIALECT_MAP as the SINGLE authoritative fire-gate. The previous
// guard (`validWords.has OR NOT sisterValidWords.has → skip`) silently
// suppressed jeg, ikke, bare, noen, hjem — the rule's NB-marker tokens —
// because NN's vocab-seam seeds them into validWords via every NN entry's
// translation field (e.g. `eg_pron.translation = 'jeg'` seeds `jeg` into
// NN validWords). With the guard dropped, every map-key NB token in the
// NN document direction flags (rule_id='dialect-mix'). See
// 05.1-05-SUMMARY.md for root-cause analysis.
//
// Non-map tokens still shielded by the Phase 4 sisterValidWords guards
// preserved in typo-curated.js and typo-fuzzy.js (data-gap safety net).
{"id":"nn-typo-dialect-jeg-001","text":"Eg såg at jeg sto der i går","expected":[{"rule_id":"dialect-mix","start":10,"end":13,"suggestion":"eg"}],"must_not_flag":[]}
{"id":"nn-typo-dialect-ikke-001","text":"Eg har ikke tid i dag","expected":[{"rule_id":"dialect-mix","start":7,"end":11,"suggestion":"ikkje"}],"must_not_flag":[]}
{"id":"nn-typo-dialect-bare-001","text":"Det er bare litt kaldt i dag","expected":[{"rule_id":"dialect-mix","start":7,"end":11,"suggestion":"berre"}],"must_not_flag":[]}
{"id":"nn-typo-dialect-noen-001","text":"Har du sett noen av dei","expected":[{"rule_id":"dialect-mix","start":12,"end":16,"suggestion":"nokon"}],"must_not_flag":[]}
{"id":"nn-typo-dialect-hjem-001","text":"Skal vi gå hjem no","expected":[{"rule_id":"dialect-mix","start":11,"end":15,"suggestion":"heim"}],"must_not_flag":[]}


# ES preterito/imperfecto aspectual hint rule fixtures (MOOD-02, Phase 11)
# Positive cases: aspect mismatch between temporal adverb and verb form (31)
# -- Preterito adverb + imperfecto verb -> suggest preterito (10) --
{"id":"es-imp-1","text":"Ayer yo caminaba por el parque.","expected":[{"rule_id":"es-imperfecto-hint","start":8,"end":16,"suggestion":"caminó"}],"comment":"preterito adverb 'ayer' + imperfecto caminaba -> preterito caminó"}
{"id":"es-imp-2","text":"Ayer ella hablaba con su madre.","expected":[{"rule_id":"es-imperfecto-hint","start":10,"end":17,"suggestion":"habló"}],"comment":"preterito adverb 'ayer' + imperfecto hablaba -> preterito habló"}
{"id":"es-imp-3","text":"Ayer el estudiaba mucho.","expected":[{"rule_id":"es-imperfecto-hint","start":8,"end":17,"suggestion":"estudió"}],"comment":"preterito adverb 'ayer' + imperfecto estudiaba -> preterito estudió"}
{"id":"es-imp-4","text":"Anoche ella hablaba con su madre.","expected":[{"rule_id":"es-imperfecto-hint","start":12,"end":19,"suggestion":"habló"}],"comment":"preterito adverb 'anoche' + imperfecto hablaba -> preterito habló"}

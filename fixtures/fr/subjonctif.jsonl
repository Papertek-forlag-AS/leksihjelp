// FR subjonctif trigger rule fixtures (MOOD-03, Phase 11)
// Rule id: "fr-subjonctif". Flags indicative verb after subjunctive trigger,
// but ONLY when subjunctive form differs from indicative (homophony guard).
// >=30 positive + >=15 acceptance cases.
//
// NOTE: Fixtures use triggers other than "il faut que" and use pronouns
// tu/je/nous/vous (not il/elle/ils/elles) to avoid triggering the fr-elision
// rule ("que il" -> "qu'il") and the typo rule ("faut" -> "fait").

// ── Positive cases — indicative verb after trigger, forms differ, must flag ──

// faire (irregular, all persons differ)
{"id":"fr-subj-pos-001","text":"Je veux que je fais le travail","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":15,"end":19,"suggestion":"fasse"}]}
{"id":"fr-subj-pos-002","text":"Je veux que tu fais le travail","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":15,"end":19,"suggestion":"fasses"}]}
{"id":"fr-subj-pos-003","text":"Pour que nous faisons le travail","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":14,"end":21,"suggestion":"fassions"}]}
{"id":"fr-subj-pos-004","text":"Pour que vous faites le travail","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":14,"end":20,"suggestion":"fassiez"}]}
{"id":"fr-subj-pos-005","text":"Avant que tu fais le travail","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":13,"end":17,"suggestion":"fasses"}]}
{"id":"fr-subj-pos-006","text":"Afin que tu fais le travail","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":12,"end":16,"suggestion":"fasses"}]}

// avoir (irregular, all persons differ)
{"id":"fr-subj-pos-007","text":"Pour que tu as raison","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":12,"end":14,"suggestion":"aies"}]}
{"id":"fr-subj-pos-008","text":"Pour que nous avons raison","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":14,"end":19,"suggestion":"ayons"}]}
{"id":"fr-subj-pos-009","text":"Bien que tu as raison","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":12,"end":14,"suggestion":"aies"}]}
{"id":"fr-subj-pos-010","text":"Bien que nous avons le temps","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":14,"end":19,"suggestion":"ayons"}]}


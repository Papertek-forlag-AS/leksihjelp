{"id":"fr-subj-pos-011","text":"Afin que tu vas bien","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":12,"end":15,"suggestion":"ailles"}]}
{"id":"fr-subj-pos-012","text":"Afin que vous allez bien","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":14,"end":19,"suggestion":"alliez"}]}
{"id":"fr-subj-pos-013","text":"Avant que nous allons bien","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":15,"end":21,"suggestion":"allions"}]}
{"id":"fr-subj-pos-014","text":"Je veux que tu vas bien","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":15,"end":18,"suggestion":"ailles"}]}


{"id":"fr-subj-pos-015","text":"Bien que tu es content","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":12,"end":14,"suggestion":"sois"}]}
{"id":"fr-subj-pos-016","text":"Pour que je suis content","lang":"fr","expected":[{"rule_id":"fr-subjonctif","start":12,"end":16,"suggestion":"sois"}]}


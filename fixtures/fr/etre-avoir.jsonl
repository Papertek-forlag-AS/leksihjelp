// FR passe compose auxiliary rule fixtures (FR-02, Phase 10)
// Rule id: "fr-etre-avoir". Flags wrong avoir/etre in passe compose.
// >=30 positive + >=15 acceptance cases.
//
// NOTE: Fixtures avoid j'ai/j'avais because the FR typo rule flags those
// apostrophe tokens (j'ai->j'aime) at lower priority, and dedupeOverlapping
// suppresses the fr-etre-avoir finding on the same span. Use "il a", "elle a"
// etc. instead for reliable testing.
// Also avoids feminine participles that trigger typo (allee, tombee, venue,
// devenue, nee, retourne).

// ── Positive cases — wrong auxiliary, must flag ──

// aller (etre verb) used with avoir
{"id":"fr-ea-pos-001","text":"il a alle","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":3,"end":4,"suggestion":"est"}]}
{"id":"fr-ea-pos-002","text":"elle a alle","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":5,"end":6,"suggestion":"est"}]}
{"id":"fr-ea-pos-003","text":"nous avons alle","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":5,"end":10,"suggestion":"sommes"}]}

// partir (etre verb) used with avoir
{"id":"fr-ea-pos-004","text":"il a parti","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":3,"end":4,"suggestion":"est"}]}
{"id":"fr-ea-pos-005","text":"elle a partie","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":5,"end":6,"suggestion":"est"}]}
{"id":"fr-ea-pos-006","text":"ils ont parti","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":4,"end":7,"suggestion":"sont"}]}

// arriver (etre verb) used with avoir
{"id":"fr-ea-pos-007","text":"nous avons arrive","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":5,"end":10,"suggestion":"sommes"}]}
{"id":"fr-ea-pos-008","text":"il a arrive","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":3,"end":4,"suggestion":"est"}]}
{"id":"fr-ea-pos-009","text":"elle a arrivee","lang":"fr","expected":[{"rule_id":"fr-etre-avoir","start":5,"end":6,"suggestion":"est"}]}

// tomber (etre verb) used with avoir
